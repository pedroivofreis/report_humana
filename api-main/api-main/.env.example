# ===========================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ===========================================
# Copie este arquivo para .env e ajuste os valores conforme necessário
# cp env.template .env

# ===========================================
# Configuração do Banco de Dados
# ===========================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=places_db

# ===========================================
# Configuração da Aplicação
# ===========================================
PROJECT_NAME=Humana API
API_STR=/api
API_PORT=8000

# ===========================================
# Segurança
# ===========================================
# ⚠️ IMPORTANTE: Altere estes valores em produção!
# Para gerar uma chave segura, use: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY=your-api-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ===========================================
# Logging
# ===========================================
# Valores possíveis: development, staging, production
ENVIRONMENT=development
# Valores possíveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# true para ver queries SQL no log (apenas para debug)
SQLALCHEMY_ECHO=false




# ------------------------------- user
# This is an example .env file
# Copy this file to .env and update the values according to your environment
SECRET_KEY=your-super-secret-key-here
API_KEY=your-api-key

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=humana_db

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
